# このファイルは設定項目の見本です。本物の秘密情報は入力しないでください。
# 実際に使用する値は、プロジェクト直下の `.env` に設定してください。
# 実際の `.env` はGitや公開フォルダへ含めないでください。

# LINE Developersで取得するChannel secret
LINE_CHANNEL_SECRET=

# LINE Developersで取得するChannel access token
LINE_CHANNEL_ACCESS_TOKEN=

# Google Cloudから取得したサービスアカウントJSONファイルの絶対パス
GOOGLE_APPLICATION_CREDENTIALS=

# Render用。サービスアカウントJSON全体をEnvironment Variableに設定する場合に使用
GOOGLE_SERVICE_ACCOUNT_JSON=

# 保存先GoogleスプレッドシートのID
GOOGLE_SPREADSHEET_ID=
